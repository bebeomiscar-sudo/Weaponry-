local arConn = nil

local function startAutoReload()
    if arConn then arConn:Disconnect() end
    arConn = RunService.Heartbeat:Connect(function()
        if not GunCFG.AutoReload or not GM.Remotes then return end
        local tool = getEquippedTool(); if not tool then return end
        local ammo = tool:GetAttribute("CurrentAmmo")
        if ammo and ammo <= 0 then
            pcall(function()
                GM.Remotes.WeaponHandler:FireServer(3, tool)
            end)
        end
    end)
end

-- ═══════════════════════════════════════════
-- TRIGGERBOT
-- ═══════════════════════════════════════════
local function getTriggerbotTarget()
    local origin = camera.CFrame.Position
    local dir    = camera.CFrame.LookVector * 2000
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LP.Character}
    local hit = workspace:Raycast(origin, dir, params)
    if not hit then return nil end
    local inst = hit.Instance
    while inst do
        local hum = inst:FindFirstChildOfClass("Humanoid")
        if hum then
            if hum.Health <= 0 then return nil end
            local plr = Players:GetPlayerFromCharacter(inst)
            if not plr or plr == LP then return nil end
            if TrigCFG.TeamCheck and isSameTeam(plr) then return nil end
            return inst
        end
        inst = inst.Parent
    end
    return nil
end

