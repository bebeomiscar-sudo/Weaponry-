-- AIMBOT
-- ════════════════════════════════════════
local lockedTarget = nil

local function isTargetValid(part)
    if not part or not part.Parent then return false end
    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if AimCFG.VisCheck and not isVisible(part) then return false end
    if AimCFG.TeamCheck then
        local p = Players:GetPlayerFromCharacter(part.Parent)
        if p and isSameTeam(p) then return false end
    end
    return true
end

local function findAimTarget()
    local c = getCenter()
    local best, bestDist = nil, AimCFG.FOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if AimCFG.TeamCheck and isSameTeam(p) then continue end
        local ch = p.Character; if not ch then continue end
        local hum = ch:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = getBestPart(ch, AimCFG.TargetPart)
        if not part then continue end
        if AimCFG.VisCheck and not isVisible(part) then continue end
        local sp, on = camera:WorldToScreenPoint(part.Position)
        if not on then continue end
        local dist = (Vector2.new(sp.X, sp.Y) - c).Magnitude
        if dist < bestDist then
            bestDist = dist; best = part
        end
    end
    return best
end

-- Bind at Camera + 2 so we override the game's own camera bind at Camera + 1
RunService:BindToRenderStep("wt_aimbot", Enum.RenderPriority.Camera.Value + 2, function(dt)
    camera = workspace.CurrentCamera
    if not AimCFG.On then return end

    -- Revalidate lock
    if lockedTarget and not isTargetValid(lockedTarget) then
        lockedTarget = nil
    end
    if not lockedTarget then
        lockedTarget = findAimTarget()
    end
    if not lockedTarget then return end

    local smooth = math.clamp(1 / AimCFG.Smoothness, 0.01, 1)
    local cp     = camera.CFrame.Position
    local dir    = (lockedTarget.Position - cp).Unit
    local tPitch = math.asin(math.clamp(dir.Y, -1, 1))
    local tYaw   = math.atan2(-dir.X, -dir.Z)
    local cPitch, cYaw = camera.CFrame:ToOrientation()
    local nPitch = cPitch + angleDiff(cPitch, tPitch) * smooth
    local nYaw   = cYaw   + angleDiff(cYaw,   tYaw)   * smooth

    pcall(function()
        camera.CFrame = CFrame.new(cp)
            * CFrame.Angles(0, nYaw, 0)
            * CFrame.Angles(nPitch, 0, 0)
    end)
end)

