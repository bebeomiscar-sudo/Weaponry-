-- ESP
-- ═══════════════════════════════════════════
local espObjects = {}

local function newDraw(class, color, thickness)
    local d = Drawing.new(class)
    d.Visible = false
    d.Color   = color
    if class == "Line" then d.Thickness = thickness or 1.5 end
    if class == "Text" then
        d.Size    = 13
        d.Center  = true
        d.Outline = true
        pcall(function() d.Font = Drawing.Fonts.Plex end)
    end
    return d
end

local function createESPFor(p)
    if espObjects[p] then return end
    espObjects[p] = {
        boxTop   = newDraw("Line", ESPCFG.BoxColor),
        boxBot   = newDraw("Line", ESPCFG.BoxColor),
        boxLeft  = newDraw("Line", ESPCFG.BoxColor),
        boxRight = newDraw("Line", ESPCFG.BoxColor),
        name     = newDraw("Text", ESPCFG.NameColor),
        dist     = newDraw("Text", ESPCFG.DistColor),
        hpBg     = newDraw("Line", Color3.fromRGB(0,0,0), 4),
        hpBar    = newDraw("Line", Color3.fromRGB(0,255,100), 3),
    }
end

local function hideESPFor(p)
    if not espObjects[p] then return end
    for _, d in pairs(espObjects[p]) do d.Visible = false end
end

local function removeESPFor(p)
    if not espObjects[p] then return end
    for _, d in pairs(espObjects[p]) do pcall(function() d:Remove() end) end
    espObjects[p] = nil
end

local function updateESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if not espObjects[p] then createESPFor(p) end

        local show = ESPCFG.On
        if ESPCFG.TeamCheck and isSameTeam(p) then show = false end
        local ch = p.Character
        if not show or not ch then hideESPFor(p); continue end

        local hrp  = ch:FindFirstChild("HumanoidRootPart")
        local hum  = ch:FindFirstChildOfClass("Humanoid")
        local head = ch:FindFirstChild("Head")
        if not hrp or not hum then hideESPFor(p); continue end

        local sp, onS = camera:WorldToScreenPoint(hrp.Position)
        if not onS then hideESPFor(p); continue end

        local topPos = head and head.Position + Vector3.new(0,0.8,0) or hrp.Position + Vector3.new(0,3,0)
        local botPos = hrp.Position - Vector3.new(0,2.5,0)
        local topSP  = camera:WorldToScreenPoint(topPos)
        local botSP  = camera:WorldToScreenPoint(botPos)
        local height = math.abs(topSP.Y - botSP.Y)
        local width  = height * 0.55
        local cx     = sp.X
        local topY   = math.min(topSP.Y, botSP.Y)
        local botY   = topY + height
        local lx, rx = cx - width/2, cx + width/2

        local obj = espObjects[p]

        -- Box
        obj.boxTop.From  = Vector2.new(lx,topY); obj.boxTop.To  = Vector2.new(rx,topY)
        obj.boxBot.From  = Vector2.new(lx,botY); obj.boxBot.To  = Vector2.new(rx,botY)
        obj.boxLeft.From = Vector2.new(lx,topY); obj.boxLeft.To = Vector2.new(lx,botY)
        obj.boxRight.From= Vector2.new(rx,topY); obj.boxRight.To= Vector2.new(rx,botY)
        for _, s in ipairs({"boxTop","boxBot","boxLeft","boxRight"}) do
            obj[s].Color   = ESPCFG.BoxColor
            obj[s].Visible = ESPCFG.Boxes
        end

        -- Name
        obj.name.Position = Vector2.new(cx, topY - 16)
        obj.name.Text     = p.Name
        obj.name.Color    = ESPCFG.NameColor
        obj.name.Visible  = ESPCFG.Names

        -- Distance
        local d = math.floor((camera.CFrame.Position - hrp.Position).Magnitude + 0.5)
        obj.dist.Position = Vector2.new(cx, botY + 2)
        obj.dist.Text     = d .. "m"
        obj.dist.Color    = ESPCFG.DistColor
        obj.dist.Visible  = ESPCFG.Distance

        -- Health bar
        local ratio  = math.clamp(hum.Health / math.max(hum.MaxHealth,1), 0, 1)
        local barX   = lx - 5
        obj.hpBg.From  = Vector2.new(barX, topY); obj.hpBg.To  = Vector2.new(barX, botY)
        obj.hpBar.From = Vector2.new(barX, botY); obj.hpBar.To = Vector2.new(barX, botY - height*ratio)
        obj.hpBar.Color = Color3.fromRGB(math.floor(255*(1-ratio)), math.floor(255*ratio), 40)
        obj.hpBg.Visible  = ESPCFG.Health
        obj.hpBar.Visible = ESPCFG.Health
    end
end

Players.PlayerRemoving:Connect(removeESPFor)
Players.PlayerAdded:Connect(function(p)
