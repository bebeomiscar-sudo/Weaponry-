-- ═══════════════════════════════════════════
-- CORE LOOP
-- ═══════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
    camera = workspace.CurrentCamera
    local center = getCenter()

    -- FOV circles
    if fovCircle then
        fovCircle.Position = center
        fovCircle.Radius   = AimCFG.FOV
        fovCircle.Visible  = AimCFG.On and AimCFG.DrawFOV
    end
    if saFovCircle then
        saFovCircle.Position = center
        saFovCircle.Radius   = SACFG.IgnoreFOV and 0 or SACFG.FOV
        saFovCircle.Visible  = SACFG.On and not SACFG.IgnoreFOV
    end

    -- ESP
    updateESP()

    -- No Spread
    if GunCFG.NoSpread and modulesLoaded and GM.CharInstances then
        pcall(function()
            local char = GM.CharInstances.Character or LP.Character
            if not char then return end
            for _, tool in ipairs(char:GetChildren()) do
                if tool:IsA("Tool") then
                    tool:SetAttribute("CurrentAccuracy", 0)
                end
            end
        end)
    end

    -- Triggerbot (PC only)
    if not IsMobile and TrigCFG.On then
        local tgt = getTriggerbotTarget()
        if tgt then
            if not TrigState.waiting then
                TrigState.waiting = true
                TrigState.timer   = TrigCFG.Delay / 1000
            end
            TrigState.timer = TrigState.timer - dt
            if TrigState.timer <= 0 then
                simClick()
                TrigState.waiting = false
                TrigState.timer   = 0
            end
        else
            TrigState.waiting = false; TrigState.timer = 0
        end
    end
end)

