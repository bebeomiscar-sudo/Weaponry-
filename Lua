-- AC BYPASS
-- ════════════════════════════════════════
local bypassDone = false

local function applyBypass()
    if bypassDone then
        print("[WT] Bypass already applied"); return
    end

    -- Step 1: Hook __namecall to block Kick + AntiExploit remote
    local antiRemote = nil
    pcall(function()
        antiRemote = RS:FindFirstChild("Remotes")
            and RS.Remotes:FindFirstChild("AntiExploit")
    end)

    local mt  = getrawmetatable(game)
    local old = mt.__namecall
    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local m = getnamecallmethod()
        -- Block all kick calls
        if m == "Kick" or m == "kick" or m:lower():find("kick") then return end
        -- Block AntiExploit remote fire
        if antiRemote and self == antiRemote
        and (m == "FireServer" or m == "InvokeServer") then
            return
        end
        return old(self, ...)
    end)
    setreadonly(mt, true)

    -- Step 2: Disable AC scripts by name keyword
    local acKeywords = {
        "anticheat", "antiexploit", "exploitcheck",
        "cheatdetect", "kickscript", "banhandler",
        "integritycheck", "clientintegrity",
    }
    local function killACScript(obj)
        if obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
            local n = obj.Name:lower()
            for _, kw in ipairs(acKeywords) do
                if n:find(kw) then
                    pcall(function() obj.Disabled = true end)
                    break
                end
            end
        end
    end
    for _, obj in ipairs(game:GetDescendants()) do killACScript(obj) end
    game.DescendantAdded:Connect(killACScript)

    -- Step 3: Block hidden remotes via secondary hookmetamethod on __namecall
    local blockedNames = {
        "kickplayer", "banplayer", "reportplayer",
        "anticheat", "flagplayer", "punish",
    }
    pcall(function()
        local oldNC = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local m = getnamecallmethod()
            if m == "FireServer" or m == "InvokeServer" then
                local name = (self and self.Name or ""):lower()
                for _, blocked in ipairs(blockedNames) do
                    if name:find(blocked) then return end
                end
            end
            return oldNC(self, ...)
        end))
    end)

    bypassDone = true
    print("[Weaponry Tool] AC Bypass applied ✓")
end

