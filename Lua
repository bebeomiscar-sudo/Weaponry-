-- ════════════════════════════════════════
-- UTILITY
-- ════════════════════════════════════════
local function getCenter()
    return Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
end

local function angleDiff(from, to)
    local d = to - from
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

local function isVisible(part)
    local origin = camera.CFrame.Position
    local dir    = part.Position - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LP.Character, part.Parent}
    local hit = workspace:Raycast(origin, dir, params)
    return hit == nil or hit.Instance:IsDescendantOf(part.Parent)
end

local function isSameTeam(p)
    if LP.Team and p.Team then return LP.Team == p.Team end
    local mt = LP:GetAttribute("TeamID"); local pt = p:GetAttribute("TeamID")
    if mt and pt then return string.byte(mt or "\0") == string.byte(pt or "\0") end
    return false
end

local PART_PRIORITY = {
    ["Head"]       = {"Head"},
    ["Torso"]      = {"UpperTorso", "LowerTorso", "HumanoidRootPart"},
    ["Head+Torso"] = {"Head", "UpperTorso", "LowerTorso"},
}

local function getBestPart(char, setting)
    local names = PART_PRIORITY[setting] or {"Head"}
    for _, n in ipairs(names) do
        local p = char:FindFirstChild(n)
        if p then return p end
    end
    return nil
end

