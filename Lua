-- ════════════════════════════════════════
-- AIMBOT
-- ════════════════════════════════════════
local lockedTarget = nil

local function isTargetValid(part)
    if not part or not part.Parent then return false end
    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if AimCFG.VisCheck and not isVisible(part) then return false end
    if AimCFG.TeamCheck then
        local p = Players:GetPlayerFromCharacter(part.Parent)
        if p and isSameTeam(p) then return false end
    end
    return true
end

local function findAimTarget()
    local c = getCenter()
    local best, bestDist = nil, AimCFG.FOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if AimCFG.TeamCheck and isSameTeam(p) then continue end
        local ch = p.Character; if not ch then continue end
        local hum = ch:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = getBestPart(ch, AimCFG.TargetPart)
        if not part then continue end
        if AimCFG.VisCheck and not isVisible(part) then continue end
        local sp, on = camera:WorldToScreenPoint(part.Position)
        if not on then continue end
        local dist = (Vector2.new(sp.X, sp.Y) - c).Magnitude
        if dist < bestDist then
            bestDist = dist; best = part
        end
    end
    return best
end

RunService:BindToRenderStep("wt_aimbot", Enum.RenderPriority.Camera.Value + 2, function(dt)
    camera = workspace.CurrentCamera
    if not AimCFG.On then return end
    if lockedTarget and not isTargetValid(lockedTarget) then
        lockedTarget = nil
    end
    if not lockedTarget then
        lockedTarget = findAimTarget()
    end
    if not lockedTarget then return end

    local smooth = math.clamp(1 / AimCFG.Smoothness, 0.01, 1)
    local cp     = camera.CFrame.Position
    local dir    = (lockedTarget.Position - cp).Unit
    local tPitch = math.asin(math.clamp(dir.Y, -1, 1))
    local tYaw   = math.atan2(-dir.X, -dir.Z)
    local cPitch, cYaw = camera.CFrame:ToOrientation()
    local nPitch = cPitch + angleDiff(cPitch, tPitch) * smooth
    local nYaw   = cYaw   + angleDiff(cYaw,   tYaw)   * smooth

    pcall(function()
        camera.CFrame = CFrame.new(cp)
            * CFrame.Angles(0, nYaw, 0)
            * CFrame.Angles(nPitch, 0, 0)
    end)
end)

-- ════════════════════════════════════════
-- SILENT AIM
-- ════════════════════════════════════════
local saTarget  = nil
local saConn    = nil
local saHooked  = false
local saOldIdx  = nil

local function saGetTarget()
    local c = getCenter()
    local best, bd = nil, SACFG.IgnoreFOV and math.huge or SACFG.FOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if SACFG.TeamCheck and isSameTeam(p) then continue end
        local ch = p.Character; if not ch then continue end
        local hum = ch:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = getBestPart(ch, SACFG.TargetPart)
        if not part then continue end
        if SACFG.VisCheck and not isVisible(part) then continue end
        local sp, on = camera:WorldToScreenPoint(part.Position)
        if not on then continue end
        local d = (Vector2.new(sp.X, sp.Y) - c).Magnitude
        if d < bd then bd = d; best = part end
    end
    return best
end

local function startSA()
    if not saHooked then
        local ok = pcall(function()
            saOldIdx = hookmetamethod(game, "__index", newcclosure(function(self, idx, ...)
                if SACFG.On and not checkcaller()
                and idx == "ViewportSize" and self == workspace.CurrentCamera then
                    if saTarget and math.random(1, 100) <= SACFG.HitChance then
                        local pos, on = workspace.CurrentCamera:WorldToViewportPoint(saTarget)
                        if on then return Vector2.new(pos.X * 2, pos.Y * 2) end
                    end
                end
                return saOldIdx(self, idx, ...)
            end))
        end)
        if ok then saHooked = true end
    end
    if saConn then saConn:Disconnect() end
    saConn = RunService.Heartbeat:Connect(function()
        if not SACFG.On then saTarget = nil; return end
        local tp = saGetTarget()
        saTarget = tp and tp.Position or nil
    end)
end

local function stopSA()
    SACFG.On = false; saTarget = nil
    if saConn then saConn:Disconnect(); saConn = nil end
end

-- ════════════════════════════════════════
-- RAGEBOT
-- ════════════════════════════════════════
local rbHooked = false
local rbOldNC  = nil
local WeaponHandler = nil

pcall(function()
    WeaponHandler = RS:WaitForChild("Remotes", 5)
        :WaitForChild("WeaponHandler", 5)
end)

local function rb_getClosest()
    if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    local target, bestDist = nil, RBState.maxDist
    for _, v in ipairs(Players:GetPlayers()) do
        if v == LP then continue end
        if RBState.teamCheck and isSameTeam(v) then continue end
        local ch = v.Character
        if not ch then continue end
        local head = ch:FindFirstChild("Head")
        if not head then continue end
        local hum = ch:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local dist = (LP.Character.HumanoidRootPart.Position - head.Position).Magnitude
        if dist < bestDist then
            if RBState.visCheck then
                local origin = workspace.CurrentCamera.CFrame.Position
                local dir    = head.Position - origin
                local params = RaycastParams.new()
                params.FilterType = Enum.RaycastFilterType.Exclude
                params.FilterDescendantsInstances = {LP.Character, ch}
                local hit = workspace:Raycast(origin, dir, params)
                if hit and not hit.Instance:IsDescendantOf(ch) then continue end
            end
            bestDist = dist
            target   = head
        end
    end
    return target
end

local function startRagebot()
    if rbHooked then return end
    if not WeaponHandler then
        Library:Notify("WeaponHandler remote not found", 3); return
    end
    local ok = pcall(function()
        rbOldNC = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if method == "FireServer"
            and self == WeaponHandler
            and RBState.active
            and not checkcaller() then
                local args = {...}
                if typeof(args[1]) == "number"
                and typeof(args[2]) == "number"
                and typeof(args[3]) == "table"
                and args[3].RayDir then
                    local target = rb_getClosest()
                    if target then
                        local origin = workspace.CurrentCamera.CFrame.Position
                        local dir    = (target.Position - origin).Unit
                        args[3].RayDir     = vector.create(dir.X, dir.Y, dir.Z)
                        local now          = tick()
                        args[2]            = now
                        args[3].BulletTick = now
                        return rbOldNC(self, args[1], args[2], args[3])
                    end
                end
            end
            return rbOldNC(self, ...)
        end))
    end)
    if ok then
        rbHooked = true
        Library:Notify("Ragebot hook applied", 3)
    else
        Library:Notify("Ragebot hook FAILED", 3)
    end
end

local function stopRagebot()
    RBState.active = false
    Library:Notify("Ragebot disabled", 2)
end

